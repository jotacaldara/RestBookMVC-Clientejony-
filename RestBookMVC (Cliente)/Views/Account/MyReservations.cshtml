@using RestBookMVC__Cliente_.DTOs
@model List<ReservationListDTO>
@{
    ViewData["Title"] = "Minhas Reservas";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Minhas Reservas</h2>
            <p class="text-muted small">Gerencie seus agendamentos</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm rounded-pill px-3">
            <i class="bi bi-plus-lg"></i> Nova Reserva
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-3 border border-dashed">
            <i class="bi bi-calendar-x display-4 text-muted opacity-50"></i>
            <h5 class="mt-3 fw-bold text-secondary">Nenhuma reserva encontrada</h5>
            <p class="text-muted">Que tal experimentar algo novo hoje?</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-2">Explorar Restaurantes</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var res in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden">
                        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3 pb-0">
                            
                            @{
                                var badgeClass = res.Status switch
                                {
                                    "Confirmed" => "bg-success",
                                    "Pending" => "bg-warning text-dark",
                                    "Canceled" => "bg-secondary",
                                    _ => "bg-light text-dark border"
                                };
                                var statusLabel = res.Status switch
                                {
                                    "Confirmed" => "Confirmado",
                                    "Pending" => "Pendente",
                                    "Canceled" => "Cancelado",
                                    _ => res.Status
                                };
                            }
                            <span class="badge @badgeClass rounded-pill">@statusLabel</span>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary mb-3">@res.RestaurantName</h5>
                            
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-calendar-event text-muted me-2"></i>
                                <span>@res.ReservationDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-clock text-muted me-2"></i>
                                <span>@res.ReservationDate.ToString("HH:mm")</span>
                            </div>

                            <div class="d-flex align-items-center">
                                <i class="bi bi-people text-muted me-2"></i>
                                <span>@res.NumberOfPeople Pessoas</span>
                            </div>
                        </div>

                        <div class="card-footer bg-light border-0 p-3">
                            @if (res.ReservationDate > DateTime.Now && res.Status != "Canceled")
                            {
                                <form asp-action="CancelReservation" asp-controller="Account" method="post" onsubmit="return confirm('Tem certeza que deseja cancelar esta reserva?');">
                                    <input type="hidden" name="id" value="@res.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-bold">
                                        <i class="bi bi-x-circle me-1"></i> Cancelar Reserva
                                    </button>
                                </form>
                            }
                            else
                            {
                                @if (res.ReservationDate < DateTime.Now && res.Status == "Confirmed")
                                {
                                    @if (res.IsReviewed)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm w-100 fw-bold" disabled>
                                            <i class="bi bi-check-circle-fill"></i> Já avaliou esta reserva
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-warning btn-sm w-100 fw-bold text-dark"
                                                data-bs-toggle="modal" data-bs-target="#reviewModal"
                                                onclick="setReviewId(@res.Id, '@res.RestaurantName')">
                                            <i class="bi bi-star-half"></i> Avaliar Experiência
                                        </button>
                                    }
                                }
                               
                            }
                           
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="SubmitReview" asp-controller="Restaurants" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Avaliar <span id="modalRestName"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="ReservationId" id="modalResId" />

                    <div class="mb-3 text-center">
                        <label class="form-label d-block fw-bold">Quantas estrelas?</label>
                        <div class="rating-css">
                            <select name="Rating" class="form-select text-center fs-5 text-warning fw-bold">
                                <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                                <option value="4">⭐⭐⭐⭐ (4)</option>
                                <option value="3">⭐⭐⭐ (3)</option>
                                <option value="2">⭐⭐ (2)</option>
                                <option value="1">⭐ (1)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Seu comentário</label>
                        <textarea name="Comment" class="form-control" rows="3" required placeholder="Como foi a comida e o atendimento?"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Enviar Avaliação</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function setReviewId(id, name) {
        document.getElementById('modalResId').value = id;
        document.getElementById('modalRestName').innerText = name;
    }
</script>
@using RestBookMVC__Cliente_.DTOs
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using RestBookMVC__Cliente_
@inject IStringLocalizer<SharedResource> Localizer
@model LoginDTO

@{
    ViewData["Title"] = Localizer["Login_Title"].Value;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-4">
        <div class="card border-0 shadow-lg p-4">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <i class="bi bi-cup-hot-fill text-primary" style="font-size: 2.5rem;"></i>
                    </div>
                    <h2 class="fw-bold text-primary">RestBook</h2>
                    <p class="text-muted">@Localizer["Login_Subtitle"]</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">@Localizer["Login_Email"]</label>
                        <input asp-for="Email" class="form-control" placeholder="@Localizer["Login_EmailPlaceholder"]" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold">@Localizer["Login_Password"]</label>
                        <input asp-for="Password" class="form-control" placeholder="@Localizer["Login_PasswordPlaceholder"]" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">
                        <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["Login_Submit"]
                    </button>
                </form>

                <div class="text-center mt-4">
                    <p class="small text-muted">
                        @Localizer["Login_NoAccount"]
                        <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-semibold">@Localizer["Login_Register"]</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@using RestBookMVC__Cliente_.DTOs
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using RestBookMVC__Cliente_
@inject IStringLocalizer<RestBookMVC__Cliente_.SharedResource> Localizer
@model List<RestaurantListDTO>

@{
    ViewData["Title"] = Localizer["Home_Title"].Value;
}

<style>
    .hero-section {
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?ixlib=rb-4.0.3&auto=format&fit=crop&w=1470&q=80');
        background-size: cover;
        background-position: center;
        border-radius: 24px !important;
        padding: 100px 20px !important;
        color: white;
    }

    .search-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 10px;
        border-radius: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .search-input {
        border: none !important;
        box-shadow: none !important;
        padding-left: 25px;
    }

    /* Fix: use padding-bottom no wrapper para o card nao empurrar os outros */
    .card-hover-wrapper {
        padding-bottom: 10px;
        transition: padding-bottom 0.3s cubic-bezier(.25,.8,.25,1);
    }

        .card-hover-wrapper:hover {
            padding-top: 0;
            padding-bottom: 10px;
        }

    .restaurant-card {
        transition: transform 0.3s cubic-bezier(.25,.8,.25,1), box-shadow 0.3s cubic-bezier(.25,.8,.25,1);
        border-radius: 16px;
        overflow: hidden;
        /* Garante que o card nao sai do flow e nao faz os outros cards saltarem */
        will-change: transform;
        position: relative;
        z-index: 0;
    }

        .restaurant-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15) !important;
            z-index: 2;
        }

    /* Linha de cards com overflow visivel para o hover nao ser cortado */
    .cards-row {
        overflow: visible !important;
    }

    .img-wrapper {
        position: relative;
        overflow: hidden;
        height: 200px;
        background-color: #f0f0f0;
    }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            /* Previne que a imagem "salte" ao carregar */
            transition: none;
        }

    .badge-rating {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background: white;
        padding: 5px 12px;
        border-radius: 10px;
        font-weight: bold;
        color: #111;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .card-title {
        font-size: 1.25rem;
        letter-spacing: -0.5px;
    }
</style>

<div class="hero-section text-center mb-5 shadow-lg">
    <h1 class="display-3 fw-bold mb-3">@Localizer["Home_HeroTitle"]</h1>
    <p class="fs-5 mb-4 opacity-75">@Localizer["Home_HeroSubtitle"]</p>

    <div class="search-container">
        <form asp-action="Index" method="get" class="row g-0 align-items-center">
            <div class="col">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="city" class="form-control search-input" placeholder="@Localizer["Home_SearchPlaceholder"]">
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 me-1">@Localizer["Home_SearchButton"]</button>
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-shop display-1 text-muted opacity-25"></i>
        <h4 class="mt-3 text-muted">@Localizer["Restaurants_NoResults"]</h4>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold text-dark mb-0">
            <i class="bi bi-grid-3x3-gap me-2 text-primary"></i>
            @Localizer["Restaurants_Title"] <span class="badge bg-primary ms-2">@Model.Count</span>
        </h5>
    </div>

    <div class="row g-4 cards-row">
        @foreach (var r in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card restaurant-card h-100 border-0 shadow-sm">
                    <div class="img-wrapper">
                        <img src="@r.ImageUrl"
                             alt="@r.Name"
                             onerror="this.onerror=null; this.src='/img/default-restaurant.jpg';" />
                        <div class="badge-rating">
                            <i class="bi bi-star-fill text-warning me-1"></i>
                            @r.AverageRating.ToString("0.0")
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mb-1">@r.Name</h5>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill text-primary me-1"></i>@r.City
                        </p>
                        <div class="d-flex gap-2 mt-auto">
                            <a asp-controller="Restaurants" asp-action="Details" asp-route-id="@r.Id"
                               class="btn btn-outline-primary btn-sm flex-fill">
                                <i class="bi bi-eye me-1"></i>@Localizer["Restaurants_ViewDetails"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

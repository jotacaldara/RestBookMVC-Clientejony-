@using RestBookMVC__Cliente_.DTOs
@model List<RestaurantListDTO>

<style>
    .hero-section {
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?ixlib=rb-4.0.3&auto=format&fit=crop&w=1470&q=80');
        background-size: cover;
        background-position: center;
        border-radius: 24px !important;
        padding: 100px 20px !important;
        color: white;
    }

    .search-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 10px;
        border-radius: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .search-input {
        border: none !important;
        box-shadow: none !important;
        padding-left: 25px;
    }

    .restaurant-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-radius: 16px;
        overflow: hidden;
    }

        .restaurant-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .img-wrapper {
        position: relative;
    }

    .badge-rating {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background: white;
        padding: 5px 12px;
        border-radius: 10px;
        font-weight: bold;
        color: #111;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .card-title {
        font-size: 1.25rem;
        letter-spacing: -0.5px;
    }
</style>

<div class="hero-section text-center mb-5 shadow-lg">
    <h1 class="display-3 fw-extrabold mb-3">Onde vamos comer hoje?</h1>
    <p class="fs-5 mb-4 opacity-75">Descubra e reserve os melhores restaurantes da sua cidade.</p>

    <div class="search-container">
        <form asp-action="Index" method="get" class="row g-0 align-items-center">
            <div class="col">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="city" class="form-control search-input" placeholder="Digite a cidade (ex: Lisboa, Porto...)">
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 me-1">Buscar</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var r in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card restaurant-card h-100 border-0 shadow-sm">
                <div class="img-wrapper">
                    <img src="@r.ImageUrl" class="card-img-top" alt="@r.Name" style="height: 240px; object-fit: cover;">
                    <div class="badge-rating">
                        <i class="bi bi-star-fill text-warning me-1"></i> @r.AverageRating.ToString("0.0")
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold mb-0">@r.Name</h5>
                    </div>

                    <p class="text-muted small mb-3">
                        <i class="bi bi-geo-alt-fill text-primary me-1"></i> @r.City
                    </p>

                    <p class="card-text text-secondary small mb-4" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @r.Description
                    </p>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">@r.TotalReviews avaliações</span>
                        <a href="/Restaurants/Details/@r.Id" class="btn btn-outline-dark btn-sm rounded-pill px-4 fw-semibold">
                            Ver Detalhes
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
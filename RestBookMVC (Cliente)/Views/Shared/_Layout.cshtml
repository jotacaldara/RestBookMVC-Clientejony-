<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestBook - Experiências Gastronômicas</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-color: #e63946; /* Vermelho moderno estilo foodie */
            --secondary-color: #1d3557;
            --bg-light: #f8f9fa;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            color: #333;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background-color: rgba(255, 255, 255, 0.95) !important;
            border-bottom: 1px solid #eee;
        }

        .navbar-brand {
            font-size: 1.5rem;
            letter-spacing: -1px;
            color: var(--primary-color) !important;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border: none;
            font-weight: 600;
            padding: 0.6rem 1.5rem;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #c12a36;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(230, 57, 70, 0.3);
            }

        .footer {
            background-color: #111 !important;
            border-top: 5px solid var(--primary-color);
        }

        /* Utilitários de sombra */
        .shadow-sm-custom {
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top shadow-sm-custom mb-4">
        <div class="container">
            <a class="navbar-brand fw-extrabold" href="/">
                <i class="bi bi-egg-fried me-2"></i>RestBook
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-semibold text-dark px-3" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> Olá, @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2">
                                <li>
                                    <a class="dropdown-item rounded-2" asp-controller="Account" asp-action="MyReservations">
                                        <i class="bi bi-calendar-check me-2"></i>Minhas Reservas
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item rounded-2 text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sair
                                    </a>
                                </li>
                        

                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-semibold px-3" asp-controller="Account" asp-action="Login">Entrar</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary rounded-pill px-4 ms-lg-2" asp-controller="Account" asp-action="Register">Cadastrar</a>
                        </li>
                    }
                </ul>
            </div>
            @await Html.PartialAsync("_LanguageSwitcher")
        </div>
    </nav>

    <main class="container min-vh-100">
        <partial name="_CookieConsentPartial" />

        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-5 py-5 text-white">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <h4 class="fw-bold mb-0">RestBook</h4>
                    <p class="text-secondary small">A melhor forma de reservar sua mesa.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-0 text-secondary">&copy; 2026 RestBook - Todos os direitos reservados.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
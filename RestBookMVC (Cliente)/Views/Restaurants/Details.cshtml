@model RestBookMVC__Cliente_.DTOs.RestaurantDetailDTO

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm overflow-hidden mb-4">
                <img src="@(Model.Images?.FirstOrDefault() ?? "/img/default-restaurant.jpg")" class="img-fluid" style="width: 100%; height: 400px; object-fit: cover;" />
                <div class="card-body p-4">
                    <h1 class="fw-bold">@Model.Name</h1>
                    <p class="text-muted"><i class="bi bi-geo-alt-fill text-primary"></i> @Model.Address, @Model.City</p>
                    <hr />
                    <h5 class="fw-bold">Sobre o Restaurante</h5>
                    <p class="text-secondary">@Model.Description</p>

                    <div class="d-flex align-items-center mb-2">
                        <div class="text-warning me-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Round(Model.AverageRating))
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                                else
                                {

                                    <i class="bi bi-star"></i>
                                }
                            }
                        </div>
                        <span class="fw-bold">@Model.AverageRating.ToString("0.0")</span>
                        <span class="text-muted ms-1">(@Model.TotalReviews avaliações)</span>
                    </div>

                </div>
            </div>


            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-journal-richtext text-primary"></i> Cardápio (Pré-pedido)</h5>
                </div>
                <div class="card-body">
                    @* O formulário deve envolver as duas colunas ou ser fechado corretamente *@
                    <form asp-controller="Restaurants" asp-action="Reserve" method="post">
                        <input type="hidden" name="RestaurantId" value="@Model.Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Data e Hora da Reserva</label>
                                @* O name deve ser "ReservationDate" para bater com o DTO *@
                                <input type="datetime-local" name="ReservationDate" class="form-control" required
                                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Número de Pessoas</label>
                                @* O name deve ser "NumberOfPeople" *@
                                <select name="NumberOfPeople" class="form-select">
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <option value="@i">@i Pessoas</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-3">Confirmar Reserva</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">

            <!-- Card Informações -->
            <div class="card border-0 shadow-sm p-4 info-card mb-4">
                <h5 class="fw-bold">Informações</h5>

                <ul class="list-unstyled mt-3">
                    <li class="mb-2">
                        <i class="bi bi-clock text-primary me-2"></i> Aberto agora
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-telephone text-primary me-2"></i> @Model.Phone
                    </li>
                </ul>

                <p class="text-muted small mt-3">
                    <i class="bi bi-shield-check"></i>
                    Sua reserva é confirmada instantaneamente no sistema do restaurante.
                </p>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-chat-left-text text-primary me-2"></i>
                    Comentários dos Clientes
                </h5>

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="mb-3 pb-3 border-bottom">

                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong class="small">@review.UserName</strong>
                                <span class="text-muted small">@review.Date</span>
                            </div>

                            <div class="text-warning mb-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= review.Rating)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                            </div>

                            <p class="mb-0 text-secondary small">
                                “@review.Comment”
                            </p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-0">
                        Ainda não há comentários para este restaurante.
                    </p>
                }
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
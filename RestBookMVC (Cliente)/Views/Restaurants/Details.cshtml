@using RestBookMVC__Cliente_.DTOs
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using RestBookMVC__Cliente_
@inject IStringLocalizer<SharedResource> Localizer
@model RestaurantDetailDTO

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house me-1"></i>@Localizer["Details_Home"]
                </a>
            </li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-4">

        <!-- Coluna Principal -->
        <div class="col-lg-8">

            <!-- Imagem e Info Principal -->
            <div class="card border-0 shadow-sm overflow-hidden mb-4">
                <img src="@(Model.Images?.FirstOrDefault() ?? "/img/default-restaurant.jpg")"
                     class="img-fluid"
                     style="width: 100%; height: 400px; object-fit: cover;"
                     alt="@Model.Name"
                     onerror="this.src='/img/default-restaurant.jpg'" />
                <div class="card-body p-4">
                    <h1 class="fw-bold mb-1">@Model.Name</h1>
                    <p class="text-muted">
                        <i class="bi bi-geo-alt-fill text-primary me-1"></i>@Model.Address, @Model.City
                    </p>

                    <!-- Rating -->
                    <div class="d-flex align-items-center mb-3">
                        <div class="text-warning me-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Round(Model.AverageRating))
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star"></i>
                                }
                            }
                        </div>
                        <span class="fw-bold me-1">@Model.AverageRating.ToString("0.0")</span>
                        <span class="text-muted small">(@Model.TotalReviews @Localizer["Details_Reviews"])</span>
                    </div>

                    <hr />

                    <h5 class="fw-bold mb-2">@Localizer["Details_AboutTitle"]</h5>
                    <p class="text-secondary">@Model.Description</p>
                </div>
            </div>

            <!-- Galeria de Imagens Adicionais -->
            @if (Model.Images != null && Model.Images.Count > 1)
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-3">
                        <div class="row g-2">
                            @foreach (var img in Model.Images.Skip(1))
                            {
                                <div class="col-4">
                                    <img src="@img" class="img-fluid rounded" style="height:120px; object-fit:cover; width:100%;"
                                         alt="@Model.Name" onerror="this.src='/img/default-restaurant.jpg'" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Menu -->
            @if (Model.MenuCategories != null && Model.MenuCategories.Any())
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                        <h4 class="fw-bold mb-0">
                            <i class="bi bi-menu-button-wide text-primary me-2"></i>@Localizer["Details_MenuTitle"]
                        </h4>
                    </div>
                    <div class="card-body p-4">
                        @foreach (var category in Model.MenuCategories)
                        {
                            <h6 class="text-uppercase fw-bold text-muted border-bottom pb-2 mb-3">@category.Name</h6>
                            @foreach (var product in category.Products)
                            {
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <p class="fw-semibold mb-0">@product.Name</p>
                                        <small class="text-muted">@product.Description</small>
                                    </div>
                                    <span class="badge bg-primary-subtle text-primary fs-6 ms-3 flex-shrink-0">
                                        @product.Price.ToString("C2", new System.Globalization.CultureInfo("pt-PT"))
                                    </span>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body p-4 text-center text-muted">
                        <i class="bi bi-journal-x display-4 opacity-25"></i>
                        <p class="mt-2">@Localizer["Details_NoMenu"]</p>
                    </div>
                </div>
            }

            <!-- Avaliações -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                    <h4 class="fw-bold mb-0">
                        <i class="bi bi-chat-square-quote text-warning me-2"></i>@Localizer["Details_ReviewsTitle"]
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (Model.Reviews == null || !Model.Reviews.Any())
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-chat-right-dots display-4 opacity-25"></i>
                            <p class="mt-2">@Localizer["Details_NoReviews"]</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2"
                                             style="width:36px; height:36px; font-weight:bold;">
                                            @(review.UserName?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <div>
                                            <p class="mb-0 fw-semibold">@review.UserName</p>
                                            <small class="text-muted">@review.Date.ToString()</small>
                                        </div>
                                    </div>
                                    <div class="text-warning">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                    </div>
                                </div>
                                <p class="mb-0 text-secondary">@review.Comment</p>
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <div class="bg-light rounded p-2 mt-2">
                                        <small class="text-muted fw-semibold">
                                            <i class="bi bi-reply me-1"></i>@Localizer["Details_RestaurantReply"]:
                                        </small>
                                        <p class="mb-0 small">@review.Comment</p>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Coluna Lateral (Reserva + Contacto) -->
        <div class="col-lg-4">

            <!-- Painel de Reserva -->
            <div class="card border-0 shadow-sm mb-4 position-sticky" style="top: 20px;">
                <div class="card-header bg-primary text-white border-0 rounded-top">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-calendar-plus me-2"></i>@Localizer["Details_ReserveTitle"]
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Restaurants" asp-action="Reserve" method="post">
                            <input type="hidden" name="RestaurantId" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label fw-semibold">@Localizer["Details_ReserveDate"]</label>
                                <input type="datetime-local" name="ReservationDate" class="form-control"
                                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">@Localizer["Details_ReservePeople"]</label>
                                <select name="NumberOfPeople" class="form-select" required>
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i">@i @Localizer["MyRes_People"]</option>
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-bold py-2">
                                <i class="bi bi-check-circle me-2"></i>@Localizer["Details_ReserveButton"]
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <i class="bi bi-lock-fill display-4 text-muted opacity-50"></i>
                            <p class="text-muted mt-2">@Localizer["Details_ReserveLoginRequired"]</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary w-100 fw-bold">
                                <i class="bi bi-box-arrow-in-right me-2"></i>@Localizer["Login_Submit"]
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Contacto -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-info-circle text-primary me-2"></i>@Localizer["Details_ContactTitle"]
                    </h6>
                </div>
                <div class="card-body p-3">
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="d-flex mb-2">
                            <i class="bi bi-geo-alt text-muted me-2 mt-1"></i>
                            <div>
                                <small class="text-muted d-block">@Localizer["Details_Address"]</small>
                                <span class="small">@Model.Address, @Model.City</span>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="d-flex mb-2">
                            <i class="bi bi-telephone text-muted me-2 mt-1"></i>
                            <div>
                                <small class="text-muted d-block">@Localizer["Details_Phone"]</small>
                                <a href="tel:@Model.Phone" class="small text-decoration-none">@Model.Phone</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
